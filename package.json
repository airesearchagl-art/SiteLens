{
  "name": "sitelens",
  "version": "0.2.0",
  "description": "SiteLens - Construction media review tool",
  "author": "AI Research AGL",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check main.js && node --check preload.js && node --check renderer.js",
    "build": "npm run dist",
    "dist": "electron-builder --win nsis"
  },
  "build": {
    "appId": "jp.airesearchagl.sitelens",
    "productName": "SiteLens",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "airesearchagl-art",
        "repo": "SiteLens"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "package.json",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/ffmpeg/win",
        "to": "ffmpeg/win",
        "filter": [
          "ffmpeg.exe",
          "ffprobe.exe"
        ]
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "SiteLens Setup.exe"
    },
    "nsis": {
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SiteLens"
    }
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1"
  }
}
